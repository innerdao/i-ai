import asyncio
from agents import planner, researcher, coder, designer, writer, analyst, executor

class YaII:
    def __init__(self):
        self.agents = {
            'planner': planner.Planner(),
            'researcher': researcher.Researcher(),
            'coder': coder.Coder(),
            'designer': designer.Designer(),
            'writer': writer.Writer(),
            'analyst': analyst.Analyst(),
            'executor': executor.Executor()
        }
        self.memory = []  # История задач
    
    async def execute_task(self, user_input: str):
        # Шаг 1: Планировщик разбивает задачу на подзадачи
        plan = await self.agents['planner'].create_plan(user_input)
        
        results = []
        for step in plan.steps:
            # Выбираем нужного агента
            agent = self.agents[step.agent_type]
            result = await agent.execute(step.description)
            results.append(result)
            
            # Сохраняем в память
            self.memory.append({
                'task': step.description,
                'result': result,
                'agent': step.agent_type
            })
        
        # Финальный сбор результата
        return self._compile_results(results)
